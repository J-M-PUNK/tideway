{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:html": "htmlhint \"index.html\"",
    "lint:all": "npm run lint && npm run lint:css && npm run lint:html && npm run format:check",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html,json}\" \"index.html\" \"*.{json,js,cjs,mjs}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,html,json}\" \"index.html\" \"*.{json,js,cjs,mjs}\"",
    "prepare": "cd .. && husky web/.husky"
  },
  "lint-staged": {
    "web/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=999"
    ],
    "web/**/*.{js,cjs,mjs,json,css,html,md}": [
      "prettier --write"
    ],
    "web/index.html": [
      "htmlhint"
    ],
    "web/src/**/*.css": [
      "stylelint --fix"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-average-color": "^9.5.2",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "htmlhint": "^1.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^36.0.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
